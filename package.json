{
	"name": "scroll-behavior",
	"version": "0.1.0",
	"description": "Framework-agnostic chat scroll behavior for loading older and newer messages.",
	"type": "module",
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		},
		"./package.json": "./package.json"
	},
	"files": [
		"dist",
		"README.md",
		"LICENSE"
	],
	"sideEffects": false,
	"engines": {
		"node": ">=18"
	},
	"scripts": {
		"build": "tsup && tsc -p tsconfig.build.json",
		"check": "npm run typecheck && npm run typecheck:examples && npm run test && npm run build && npm run test:package && npm run pack:dry",
		"pack:dry": "npm pack --dry-run --cache ./.npm-cache",
		"test": "vitest run",
		"test:package": "node scripts/verify-package.mjs",
		"typecheck": "tsc --noEmit",
		"typecheck:examples": "tsc -p tsconfig.examples.json"
	},
	"keywords": [
		"chat",
		"scroll",
		"infinite-scroll",
		"react",
		"nextjs",
		"messages"
	],
	"license": "MIT",
	"peerDependencies": {
		"react": ">=19.2.5"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"happy-dom": "^20.9.0",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"tsup": "^8.5.1",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
